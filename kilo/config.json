{
  "$schema": "https://kilo.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "ls": "allow",
      "cd *": "allow",
      "cd": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "which *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "echo *": "allow",
      "date": "allow",
      "whoami": "allow",
      "git status *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ag *": "allow",
      "ack *": "allow",
      "less *": "allow",
      "more *": "allow"
    },
    "cmd": "ask",
    "webfetch": "ask",
    "edit": "ask",
    "write": "ask",
    "read": "allow",
    "list": "allow",
    "grep": "allow",
    "glob": "allow",
    "ls": "allow"
  },
  "agent": {
    "Auto_Code": {
      "mode": "primary",
      "description": "Code mode that doesn't require permission to make edits",
      "permission": {
        "edit": "allow",
        "write": "allow"
      }
    }
  }
}
