[submodule "tmux/plugins/tmux"]
	path = tmux/plugins/tmux
	url = https://github.com/catthode/tmux
[submodule "tmux/plugins/tpm"]
	path = tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm
	ignore = dirty
[submodule "zsh/fzf-git"]
	path = zsh/fzf-git
	url = https://github.com/junegunn/fzf-git.sh.git
[submodule "zsh/powerlevel10k"]
	path = zsh/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k.git
[submodule "zsh/fast-syntax-highlighting"]
	path = zsh/fast-syntax-highlighting
	url = https://github.com/zdharma-continuum/fast-syntax-highlighting.git
